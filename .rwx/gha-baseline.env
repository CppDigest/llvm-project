# GitHub Actions baseline timings (seconds).
# Populate by running .github/workflows/monolithic-linux-baseline.yml once,
# then copy the output from the job summary into this file.
#
# When writing reports, also check upstream llvm-project GitHub Actions history
# for reference: https://github.com/llvm/llvm-project/actions
# Filter by "CI Checks" or "llvm-project-tests" workflow for build/test timings.
#
# Example (replace with real numbers from GHA run):
# GHA_CONFIGURE_S=600
# GHA_BUILD_S=7200
# GHA_CHECK_S=5400
# GHA_TOTAL_S=14400

GHA_CONFIGURE_S=0
GHA_BUILD_S=0
GHA_CHECK_S=0
GHA_TOTAL_S=0
